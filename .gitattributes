# Normalize all text files to LF on checkout (prevents CRLF issues on Windows)
* text=auto eol=lf

# Shell scripts — must always be LF or bash will fail with "invalid option name"
*.sh text eol=lf

# Dockerfile and config text files
Dockerfile text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.md text eol=lf

# Binary / LFS files — no line-ending conversion
*.mbtiles filter=lfs diff=lfs merge=lfs -text
*.ppg filter=lfs diff=lfs merge=lfs -text
*.pjg filter=lfs diff=lfs merge=lfs -text
*.mrf filter=lfs diff=lfs merge=lfs -text
*.idx filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
